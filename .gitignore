# Data — never commit the dataset (large; provided separately)
dataset/*.csv
dataset/*.zip
dataset/*.gz
# enriched supplemental sources + raw downloads (rebuildable via tools/)
dataset/supplemental/
dataset/_raw/
!dataset/.gitkeep

# Trained artifacts
*.joblib
mae_by_city.csv

# Large OSM extracts / temp download dirs (enrichment); keep the small lookup CSVs
*.osm.pbf
enrichment/_tmp/
enrichment/*.log
enrichment/dataset/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# OS / editor
.DS_Store
.idea/
.vscode/
